{% extends 'base.html.twig' %}

{% block title %}{{ user ? 'Edit User' : 'New User' }}{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 700px;">

    <h1>{{ user ? 'Edit User' : 'New User' }}</h1>

    {% for error in errors %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endfor %}

    <form method="POST" action="{{ user
        ? path('symfony_crud_user_update', {id: user.id})
        : path('symfony_crud_user_store') }}">

        <input type="hidden" name="_token" value="{{ csrf_token('submit') }}">

        <h5 class="mt-3">Business Fields</h5>

        <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-control"
                   value="{{ form_data.email ?? (user ? user.email : '') }}"
                   minlength="6" maxlength="50" required>
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">
                Password{% if user %} <small class="text-muted">(leave blank to keep current)</small>{% endif %}
            </label>
            <input type="password" id="password" name="password" class="form-control"
                   minlength="6" maxlength="50" {{ user ? '' : 'required' }}>
        </div>

        <hr>
        <h5 class="mt-3">PostgreSQL Type Coverage</h5>

        <div class="mb-3">
            <label for="colText" class="form-label">colText</label>
            <textarea id="colText" name="colText" class="form-control" rows="3">{{ form_data.colText ?? (user ? user.colText : '') }}</textarea>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colInteger" class="form-label">colInteger</label>
                <input type="number" id="colInteger" name="colInteger" class="form-control" step="1"
                       value="{{ form_data.colInteger ?? (user ? user.colInteger : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colSmallint" class="form-label">colSmallint</label>
                <input type="number" id="colSmallint" name="colSmallint" class="form-control" step="1"
                       value="{{ form_data.colSmallint ?? (user ? user.colSmallint : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colBigint" class="form-label">colBigint</label>
                <input type="text" id="colBigint" name="colBigint" class="form-control"
                       value="{{ form_data.colBigint ?? (user ? user.colBigint : '') }}">
            </div>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colDecimal" class="form-label">colDecimal</label>
                <input type="text" id="colDecimal" name="colDecimal" class="form-control"
                       value="{{ form_data.colDecimal ?? (user ? user.colDecimal : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colFloat" class="form-label">colFloat</label>
                <input type="number" id="colFloat" name="colFloat" class="form-control" step="any"
                       value="{{ form_data.colFloat ?? (user ? user.colFloat : '') }}">
            </div>
        </div>

        <div class="mb-3">
            <label for="colBoolean" class="form-label">colBoolean</label>
            <select id="colBoolean" name="colBoolean" class="form-select">
                {% set boolVal = form_data.colBoolean ?? (user and user.colBoolean is not null ? (user.colBoolean ? '1' : '0') : '') %}
                <option value=""  {{ boolVal == ''  ? 'selected' : '' }}>Null</option>
                <option value="1" {{ boolVal == '1' ? 'selected' : '' }}>True</option>
                <option value="0" {{ boolVal == '0' ? 'selected' : '' }}>False</option>
            </select>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colDatetimetz" class="form-label">colDatetimetz</label>
                <input type="datetime-local" id="colDatetimetz" name="colDatetimetz" class="form-control"
                       value="{{ form_data.colDatetimetz ?? (user and user.colDatetimetz ? user.colDatetimetz|date('Y-m-d\\TH:i') : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colDate" class="form-label">colDate</label>
                <input type="date" id="colDate" name="colDate" class="form-control"
                       value="{{ form_data.colDate ?? (user and user.colDate ? user.colDate|date('Y-m-d') : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colTime" class="form-label">colTime</label>
                <input type="time" id="colTime" name="colTime" class="form-control"
                       value="{{ form_data.colTime ?? (user and user.colTime ? user.colTime|date('H:i') : '') }}">
            </div>
        </div>

        <div class="mb-3">
            <label for="colGuid" class="form-label">colGuid</label>
            <input type="text" id="colGuid" name="colGuid" class="form-control"
                   value="{{ form_data.colGuid ?? (user ? user.colGuid : '') }}"
                   placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx">
        </div>

        <div class="mb-3">
            <label for="colJson" class="form-label">colJson <small class="text-muted">(JSON)</small></label>
            <textarea id="colJson" name="colJson" class="form-control" rows="3"
                      placeholder='{"key": "value"}'>{{ form_data.colJson ?? (user and user.colJson ? user.colJson|json_encode : '') }}</textarea>
        </div>

        <div class="mb-3">
            <label for="colArray" class="form-label">colArray <small class="text-muted">(JSON array)</small></label>
            <textarea id="colArray" name="colArray" class="form-control" rows="3"
                      placeholder='["item1", "item2"]'>{{ form_data.colArray ?? (user and user.colArray ? user.colArray|json_encode : '') }}</textarea>
        </div>

        <div class="mb-3">
            <label for="colSimpleArray" class="form-label">colSimpleArray <small class="text-muted">(comma-separated)</small></label>
            <input type="text" id="colSimpleArray" name="colSimpleArray" class="form-control"
                   value="{{ form_data.colSimpleArray ?? (user and user.colSimpleArray ? user.colSimpleArray|join(', ') : '') }}"
                   placeholder="item1, item2, item3">
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">{{ user ? 'Update' : 'Create' }}</button>
            <a href="{{ path('symfony_crud_user_list') }}" class="btn btn-secondary">Cancel</a>
        </div>

    </form>

</div>
{% endblock %}
