{% extends 'base.html.twig' %}

{% block title %}{{ payment ? 'Edit Payment' : 'New Payment' }}{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 700px;">

    <h1>{{ payment ? 'Edit Payment' : 'New Payment' }}</h1>

    {% for error in errors %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endfor %}

    <form method="POST" action="{{ payment
        ? path('symfony_crud_payment_update', {id: payment.id})
        : path('symfony_crud_payment_store') }}">

        <input type="hidden" name="_token" value="{{ csrf_token('submit') }}">

        <h5 class="mt-3">Business Fields</h5>

        <div class="mb-3">
            <label for="amount" class="form-label">Amount</label>
            <input type="number" id="amount" name="amount" class="form-control"
                   value="{{ form_data.amount ?? (payment ? payment.amount : '') }}"
                   step="0.01" min="0.01" required>
        </div>

        <div class="mb-3">
            <label for="currency" class="form-label">Currency</label>
            <input type="text" id="currency" name="currency" class="form-control"
                   value="{{ form_data.currency ?? (payment ? payment.currency : 'USD') }}"
                   minlength="3" maxlength="3" required style="text-transform: uppercase;">
        </div>

        <div class="mb-3">
            <label for="status" class="form-label">Status</label>
            <select id="status" name="status" class="form-select" required>
                {% set currentStatus = form_data.status ?? (payment ? payment.status : 'pending') %}
                <option value="pending"   {{ currentStatus == 'pending'   ? 'selected' : '' }}>Pending</option>
                <option value="completed" {{ currentStatus == 'completed' ? 'selected' : '' }}>Completed</option>
                <option value="failed"    {{ currentStatus == 'failed'    ? 'selected' : '' }}>Failed</option>
                <option value="refunded"  {{ currentStatus == 'refunded'  ? 'selected' : '' }}>Refunded</option>
            </select>
        </div>

        <hr>
        <h5 class="mt-3">MariaDB Type Coverage</h5>

        <div class="mb-3">
            <label for="colText" class="form-label">colText</label>
            <textarea id="colText" name="colText" class="form-control" rows="3">{{ form_data.colText ?? (payment ? payment.colText : '') }}</textarea>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colInteger" class="form-label">colInteger</label>
                <input type="number" id="colInteger" name="colInteger" class="form-control" step="1"
                       value="{{ form_data.colInteger ?? (payment ? payment.colInteger : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colSmallint" class="form-label">colSmallint</label>
                <input type="number" id="colSmallint" name="colSmallint" class="form-control" step="1"
                       value="{{ form_data.colSmallint ?? (payment ? payment.colSmallint : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colBigint" class="form-label">colBigint</label>
                <input type="text" id="colBigint" name="colBigint" class="form-control"
                       value="{{ form_data.colBigint ?? (payment ? payment.colBigint : '') }}">
            </div>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colDecimal" class="form-label">colDecimal</label>
                <input type="text" id="colDecimal" name="colDecimal" class="form-control"
                       value="{{ form_data.colDecimal ?? (payment ? payment.colDecimal : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colFloat" class="form-label">colFloat</label>
                <input type="number" id="colFloat" name="colFloat" class="form-control" step="any"
                       value="{{ form_data.colFloat ?? (payment ? payment.colFloat : '') }}">
            </div>
        </div>

        <div class="mb-3">
            <label for="colBoolean" class="form-label">colBoolean</label>
            <select id="colBoolean" name="colBoolean" class="form-select">
                {% set boolVal = form_data.colBoolean ?? (payment and payment.colBoolean is not null ? (payment.colBoolean ? '1' : '0') : '') %}
                <option value=""  {{ boolVal == ''  ? 'selected' : '' }}>Null</option>
                <option value="1" {{ boolVal == '1' ? 'selected' : '' }}>True</option>
                <option value="0" {{ boolVal == '0' ? 'selected' : '' }}>False</option>
            </select>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colDate" class="form-label">colDate</label>
                <input type="date" id="colDate" name="colDate" class="form-control"
                       value="{{ form_data.colDate ?? (payment and payment.colDate ? payment.colDate|date('Y-m-d') : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colTime" class="form-label">colTime</label>
                <input type="time" id="colTime" name="colTime" class="form-control"
                       value="{{ form_data.colTime ?? (payment and payment.colTime ? payment.colTime|date('H:i') : '') }}">
            </div>
        </div>

        <div class="mb-3">
            <label for="colGuid" class="form-label">colGuid</label>
            <input type="text" id="colGuid" name="colGuid" class="form-control"
                   value="{{ form_data.colGuid ?? (payment ? payment.colGuid : '') }}"
                   placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx">
        </div>

        <div class="mb-3">
            <label for="colJson" class="form-label">colJson <small class="text-muted">(JSON)</small></label>
            <textarea id="colJson" name="colJson" class="form-control" rows="3"
                      placeholder='{"key": "value"}'>{{ form_data.colJson ?? (payment and payment.colJson ? payment.colJson|json_encode : '') }}</textarea>
        </div>

        <div class="mb-3">
            <label for="colArray" class="form-label">colArray <small class="text-muted">(JSON array)</small></label>
            <textarea id="colArray" name="colArray" class="form-control" rows="3"
                      placeholder='["item1", "item2"]'>{{ form_data.colArray ?? (payment and payment.colArray ? payment.colArray|json_encode : '') }}</textarea>
        </div>

        <div class="mb-3">
            <label for="colSimpleArray" class="form-label">colSimpleArray <small class="text-muted">(comma-separated)</small></label>
            <input type="text" id="colSimpleArray" name="colSimpleArray" class="form-control"
                   value="{{ form_data.colSimpleArray ?? (payment and payment.colSimpleArray ? payment.colSimpleArray|join(', ') : '') }}"
                   placeholder="item1, item2, item3">
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">{{ payment ? 'Update' : 'Create' }}</button>
            <a href="{{ path('symfony_crud_payment_list') }}" class="btn btn-secondary">Cancel</a>
        </div>

    </form>

</div>
{% endblock %}
