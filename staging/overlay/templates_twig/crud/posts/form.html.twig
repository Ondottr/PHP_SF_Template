{% extends 'base.html.twig' %}

{% block title %}{{ post ? 'Edit Post' : 'New Post' }}{% endblock %}

{% block body %}
<div class="container mt-4" style="max-width: 700px;">

    <h1>{{ post ? 'Edit Post' : 'New Post' }}</h1>

    {% for error in errors %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endfor %}

    <form method="POST" action="{{ post
        ? path('symfony_crud_post_update', {id: post.id})
        : path('symfony_crud_post_store') }}">

        <input type="hidden" name="_token" value="{{ csrf_token('submit') }}">

        <h5 class="mt-3">Business Fields</h5>

        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" id="title" name="title" class="form-control"
                   value="{{ form_data.title ?? (post ? post.title : '') }}"
                   minlength="1" maxlength="255" required>
        </div>

        <div class="mb-3">
            <label for="content" class="form-label">Content</label>
            <textarea id="content" name="content" class="form-control" rows="6">{{ form_data.content ?? (post ? post.content : '') }}</textarea>
        </div>

        <div class="mb-3">
            <label for="status" class="form-label">Status</label>
            <select id="status" name="status" class="form-select" required>
                {% set currentStatus = form_data.status ?? (post ? post.status : 'draft') %}
                <option value="draft"      {{ currentStatus == 'draft'      ? 'selected' : '' }}>Draft</option>
                <option value="published"  {{ currentStatus == 'published'  ? 'selected' : '' }}>Published</option>
                <option value="archived"   {{ currentStatus == 'archived'   ? 'selected' : '' }}>Archived</option>
            </select>
        </div>

        <hr>
        <h5 class="mt-3">MySQL Type Coverage</h5>

        <div class="row">
            <div class="col mb-3">
                <label for="colInteger" class="form-label">colInteger</label>
                <input type="number" id="colInteger" name="colInteger" class="form-control" step="1"
                       value="{{ form_data.colInteger ?? (post ? post.colInteger : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colSmallint" class="form-label">colSmallint</label>
                <input type="number" id="colSmallint" name="colSmallint" class="form-control" step="1"
                       value="{{ form_data.colSmallint ?? (post ? post.colSmallint : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colBigint" class="form-label">colBigint</label>
                <input type="text" id="colBigint" name="colBigint" class="form-control"
                       value="{{ form_data.colBigint ?? (post ? post.colBigint : '') }}">
            </div>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colDecimal" class="form-label">colDecimal</label>
                <input type="text" id="colDecimal" name="colDecimal" class="form-control"
                       value="{{ form_data.colDecimal ?? (post ? post.colDecimal : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colFloat" class="form-label">colFloat</label>
                <input type="number" id="colFloat" name="colFloat" class="form-control" step="any"
                       value="{{ form_data.colFloat ?? (post ? post.colFloat : '') }}">
            </div>
        </div>

        <div class="mb-3">
            <label for="colBoolean" class="form-label">colBoolean</label>
            <select id="colBoolean" name="colBoolean" class="form-select">
                {% set boolVal = form_data.colBoolean ?? (post and post.colBoolean is not null ? (post.colBoolean ? '1' : '0') : '') %}
                <option value=""  {{ boolVal == ''  ? 'selected' : '' }}>Null</option>
                <option value="1" {{ boolVal == '1' ? 'selected' : '' }}>True</option>
                <option value="0" {{ boolVal == '0' ? 'selected' : '' }}>False</option>
            </select>
        </div>

        <div class="row">
            <div class="col mb-3">
                <label for="colDate" class="form-label">colDate</label>
                <input type="date" id="colDate" name="colDate" class="form-control"
                       value="{{ form_data.colDate ?? (post and post.colDate ? post.colDate|date('Y-m-d') : '') }}">
            </div>
            <div class="col mb-3">
                <label for="colTime" class="form-label">colTime</label>
                <input type="time" id="colTime" name="colTime" class="form-control"
                       value="{{ form_data.colTime ?? (post and post.colTime ? post.colTime|date('H:i') : '') }}">
            </div>
        </div>

        <div class="mb-3">
            <label for="colGuid" class="form-label">colGuid</label>
            <input type="text" id="colGuid" name="colGuid" class="form-control"
                   value="{{ form_data.colGuid ?? (post ? post.colGuid : '') }}"
                   placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx">
        </div>

        <div class="mb-3">
            <label for="colJson" class="form-label">colJson <small class="text-muted">(JSON)</small></label>
            <textarea id="colJson" name="colJson" class="form-control" rows="3"
                      placeholder='{"key": "value"}'>{{ form_data.colJson ?? (post and post.colJson ? post.colJson|json_encode : '') }}</textarea>
        </div>

        <div class="mb-3">
            <label for="colArray" class="form-label">colArray <small class="text-muted">(JSON array)</small></label>
            <textarea id="colArray" name="colArray" class="form-control" rows="3"
                      placeholder='["item1", "item2"]'>{{ form_data.colArray ?? (post and post.colArray ? post.colArray|json_encode : '') }}</textarea>
        </div>

        <div class="mb-3">
            <label for="colSimpleArray" class="form-label">colSimpleArray <small class="text-muted">(comma-separated)</small></label>
            <input type="text" id="colSimpleArray" name="colSimpleArray" class="form-control"
                   value="{{ form_data.colSimpleArray ?? (post and post.colSimpleArray ? post.colSimpleArray|join(', ') : '') }}"
                   placeholder="item1, item2, item3">
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">{{ post ? 'Update' : 'Create' }}</button>
            <a href="{{ path('symfony_crud_post_list') }}" class="btn btn-secondary">Cancel</a>
        </div>

    </form>

</div>
{% endblock %}
